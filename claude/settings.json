{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git commit -m ' *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(brew install *)",
      "Bash(brew uninstall *)",
      "Bash(uv run *)",
      "Bash(uv add *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(open *)",
      "Bash(code *)",
      "Bash(cursor *)",
      "Bash(docker port *)",
      "Bash(python3 -c \":*)"
    ],
    "deny": [
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Edit(~/.ssh/**)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/Projects/personal/dotfiles/claude/hooks/soft-deny.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "if": "Bash(git push *)",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -qE '^git\\s+push\\s.*\\b(main|master)\\b' && echo '{\"decision\":\"block\",\"reason\":\"Pushing to main/master is blocked. Create a feature branch and push there instead.\"}' || echo '{\"decision\":\"allow\"}'",
            "statusMessage": "Checking push target..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "hookify@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "agentPushNotifEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  }
}
