#!/bin/sh

remote="$1"
url="$2"

while read local_ref local_oid remote_ref remote_oid; do
  if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
    range="$local_oid"
  else
    range="$remote_oid..$local_oid"
  fi

  echo ""
  echo "=== Pre-push summary ==="
  echo "Remote: $remote ($url)"
  echo "Branch: ${local_ref#refs/heads/}"
  echo ""

  echo "Commits:"
  git log --oneline "$range" 2>/dev/null
  echo ""

  echo "Changes:"
  git diff --stat "$range" 2>/dev/null
  echo ""

  # Skip prompt in non-interactive contexts (CI, scripts, AI agents)
  if [ ! -t 0 ]; then
    exit 0
  fi

  printf "Push these changes? [y/N] "
  exec < /dev/tty
  read answer
  if [ "$answer" != "y" ] && [ "$answer" != "Y" ]; then
    echo "Push aborted."
    exit 1
  fi
done

exit 0
